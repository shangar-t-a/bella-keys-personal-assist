# Bella Keys Auth Service Environment Variables
# Do not place real secrets in this file. It is a template.

# PostgreSQL Connection (used by the Docker stack)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/bella_keys

# JWT Secrets and Timing
# Generate a secure secret using: openssl rand -hex 32
JWT_SECRET=super_secret_dev_key_change_me_in_prod
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
