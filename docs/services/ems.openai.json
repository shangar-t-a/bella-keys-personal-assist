    "components": {
        "schemas": {
            "AccountNameRequest": {
                "properties": {
                    "accountName": {
                        "type": "string",
                        "title": "Accountname",
                        "description": "Name of the account",
                        "examples": [
                            "ICICI",
                            "SBI"
                        ]
                    }
                },
                "additionalProperties": false,
                "type": "object",
                "required": [
                    "accountName"
                ],
                "title": "AccountNameRequest",
                "description": "Schema for account name creation/update requests."
            },
            "AccountNameResponse": {
                "properties": {
                    "id": {
                        "type": "string",
                        "title": "Id",
                        "description": "Unique identifier for the account"
                    },
                    "accountName": {
                        "type": "string",
                        "title": "Accountname",
                        "description": "Name of the account"
                    }
                },
                "additionalProperties": false,
                "type": "object",
                "required": [
                    "id",
                    "accountName"
                ],
                "title": "AccountNameResponse",
                "description": "Schema for account name responses."
            },
            "AccountUpdateRequest": {
                "properties": {
                    "accountName": {
                        "type": "string",
                        "title": "Accountname",
                        "description": "New name for the account",
                        "examples": [
                            "ICICI"
                        ]
                    }
                },
                "additionalProperties": false,
                "type": "object",
                "required": [
                    "accountName"
                ],
                "title": "AccountUpdateRequest",
                "description": "Schema for account update requests."
            },
            "HTTPErrorResponse": {
                "properties": {
                    "detail": {
                        "type": "string",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "required": [
                    "detail"
                ],
                "title": "HTTPErrorResponse",
                "description": "Base schema for HTTP error responses."
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "PeriodRequest": {
                "properties": {
                    "month": {
                        "type": "integer",
                        "maximum": 12,
                        "minimum": 1,
                        "title": "Month",
                        "description": "Month as an integer between 1 and 12",
                        "examples": [
                            1,
                            2,
                            3
                        ]
                    },
                    "year": {
                        "type": "integer",
                        "maximum": 2100,
                        "minimum": 2000,
                        "title": "Year",
                        "description": "Year between 2000 and 2100",
                        "examples": [
                            2024,
                            2025
                        ]
                    }
                },
                "additionalProperties": false,
                "type": "object",
                "required": [
                    "month",
                    "year"
                ],
                "title": "PeriodRequest",
                "description": "Schema for month-year creation requests."
            },
            "PeriodResponse": {
                "properties": {
                    "id": {
                        "type": "string",
                        "title": "Id",
                        "description": "Unique identifier for the month-year combination"
                    },
                    "month": {
                        "type": "integer",
                        "maximum": 12,
                        "minimum": 1,
                        "title": "Month",
                        "description": "Month as an integer between 1 and 12",
                        "examples": [
                            1,
                            2,
                            3
                        ]
                    },
                    "year": {
                        "type": "integer",
                        "title": "Year",
                        "description": "Year value"
                    }
                },
                "additionalProperties": false,
                "type": "object",
                "required": [
                    "id",
                    "month",
                    "year"
                ],
                "title": "PeriodResponse",
                "description": "Schema for month-year responses."
            },
            "SpendingAccountEntryRequest": {
                "properties": {
                    "accountName": {
                        "type": "string",
                        "title": "Accountname",
                        "description": "Name of the spending account",
                        "examples": [
                            "ICICI",
                            "SBI"
                        ]
                    },
                    "month": {
